# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/

# Playwright user profile (large, machine-local)
.chrome_profile/

# All raw data stays local — only docs/index.html is committed.
# Uses data/* (not data/) so the !data/attractions.csv exception below
# is reachable; a bare data/ ignore halts traversal at the directory and
# silently swallows nested re-includes.
data/*
!data/attractions.csv

# Editor / tool state
.claude/
.idea/
.vscode/

# Local config (Gist ID, etc) — never commit
config.json

# Claude Code project context — kept local
CLAUDE.md
