# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/

# Playwright user profile (large, machine-local)
.chrome_profile/

# All raw data stays local — only docs/index.html is committed.
# Uses data/* (not data/) so the !data/attractions.csv exception below
# is reachable; a bare data/ ignore halts traversal at the directory and
# silently swallows nested re-includes.
data/*
!data/attractions.csv
!data/favorites_builtin.json

# Editor / tool state
.claude/
.idea/
.vscode/

# Local config (Gist ID, etc) — never commit
config.json

# Claude Code project context — kept local
CLAUDE.md

# One-shot / ad-hoc scripts and dev helpers that don't affect the build
# output. Kept locally for the user but not part of the repo's pipeline.
backfill_*.py
prune_*.py
run_batch.py
batch.txt
preview.ps1
preview.ps1.tmp.*
scripts/

# Audit / probe tools — they read the dataset but don't produce anything
# the map depends on. The pipeline code that does affect output
# (scrape_all.py, scrape_topup.py, map.py, transit_postprocess.py) is
# tracked normally.
src/tabelog/scrape/audit_*.py
src/tabelog/scrape/transit_audit.py

# Local rollback snapshots (e.g. map.py.bak before a big refactor)
*.bak
docs/transit/japan*.geojson
