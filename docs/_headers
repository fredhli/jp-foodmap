# Cloudflare Pages headers config.
# /emoji/* PNGs are content-addressed (hex codepoint filenames) and rebuilt
# only when the source emoji changes, so the URL changing implies the bytes
# changing. Safe to cache forever at the browser.
/emoji/*
  Cache-Control: public, max-age=31536000, immutable

# Service worker must never be stale or rollouts get stuck on old code.
/sw.js
  Cache-Control: no-cache

# Big payloads (restaurants.json, popups-*.json). The SW busts its own
# cache by VERSION on each deploy, so the HTTP layer only needs a short
# freshness window with a long SWR tail. Returning users hit disk before
# the SW even activates.
/data/*
  Cache-Control: public, max-age=300, stale-while-revalidate=86400

# transit-layer.js ships with each redeploy but isn't version-stamped,
# so keep it short-cached + revalidated like the data payloads.
/transit-layer.js
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# The HTML shell must be revalidated each visit so the SW version stamp
# and any rolled-out template tweak land immediately. Cloudflare edge can
# still cache it briefly; the must-revalidate keeps the browser honest.
/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate
